# env/.env.example
# 이 파일을 복사하여 .env로 만들고 실제 값을 채운다
# cp env/.env.example .env

# === LLM 프로바이더 ===
# "gemini" 또는 "claude"
LLM_PROVIDER=gemini

# === Gemini API (기본) ===
GOOGLE_API_KEY=your-google-api-key
GEMINI_MODEL=gemini-2.5-flash

# === Claude API (LLM_PROVIDER=claude 시) ===
ANTHROPIC_API_KEY=sk-ant-xxxxx
CLAUDE_MODEL=claude-sonnet-4-20250514

# === Fusion 360 ===
FUSION_BRIDGE_URL=http://127.0.0.1:18080
FUSION_BRIDGE_TIMEOUT=60

# === KiCad ===
KICAD_CLI_PATH=kicad-cli

# === 시뮬레이션 도구 (Docker 사용 시 비워둠) ===
CCX_PATH=ccx
GMSH_PATH=gmsh
ELMER_SOLVER_PATH=ElmerSolver
ELMER_GRID_PATH=ElmerGrid
OPENFOAM_DOCKER=true

# === ParaView ===
PARAVIEW_PATH=pvpython

# === 작업 디렉토리 ===
DATA_DIR=./data
SNAPSHOT_DIR=./data/snapshots
LOG_DIR=./data/logs
WORK_DIR=./data/work

# === 파이프라인 설정 ===
MAX_ITERATIONS=10
SOLVER_TIMEOUT=3600
